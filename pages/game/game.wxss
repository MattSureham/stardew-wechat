/* pages/game/game.wxss */

.game-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #1a1a2e;
  min-height: 100vh;
  padding: 20rpx;
}

/* HUD */
.hud {
  display: flex;
  justify-content: space-between;
  width: 100%;
  max-width: 640rpx;
  padding: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.hud-item {
  color: #fff;
  font-size: 28rpx;
}

/* Canvas */
.game-canvas {
  border: 4rpx solid #4a7c3f;
  border-radius: 8rpx;
}

/* Toolbar */
.toolbar {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.tool-btn.active {
  background: rgba(74, 124, 63, 0.6);
  border-color: #4a7c3f;
}

.tool-icon {
  font-size: 40rpx;
}

.tool-name {
  color: #fff;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* Actions */
.actions {
  display: flex;
  gap: 30rpx;
  margin-top: 30rpx;
}

.action-btn {
  width: 200rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.action-btn.confirm {
  background: #4a7c3f;
}

/* D-Pad */
.dpad {
  margin-top: 40rpx;
}

.dpad-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.dpad-btn {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
}

.dpad-btn:active {
  background: rgba(255, 255, 255, 0.3);
}
